// __NAME__ is a starter VGI worker scaffold generated by `make new-worker NAME=__NAME__`.
// It registers one typed scalar function (`__NAME___greet`) over stdio so you
// can attach from DuckDB and validate the full plumbing before adding more.
package main

import (
	"context"
	"flag"
	"fmt"
	"log"

	"github.com/Query-farm/vgi-go/vgi"
	"github.com/apache/arrow-go/v18/arrow"
	"github.com/apache/arrow-go/v18/arrow/array"
)

// greetArgs declares the function's arguments. `vgi:"..."` tags drive both
// the ArgumentSpecs (DeriveArgSpecs) and runtime binding (BindArgs).
type greetArgs struct {
	Who string `vgi:"pos=0,const=false,type=varchar,doc=Name to greet"`
}

// GreetFn is the function implementation.
type GreetFn struct{}

func (*GreetFn) Name() string { return "__NAME___greet" }

func (*GreetFn) Metadata() vgi.FunctionMetadata {
	return vgi.FunctionMetadata{
		Description: "Says hello to a name",
		Stability:   vgi.StabilityConsistent,
		ReturnType:  arrow.BinaryTypes.String,
	}
}

func (*GreetFn) OnBindTyped(_ *greetArgs, _ *vgi.BindParams) (*vgi.BindResponse, error) {
	return vgi.BindResult(arrow.BinaryTypes.String)
}

func (*GreetFn) ProcessTyped(_ context.Context, _ *greetArgs, params *vgi.ProcessParams, batch arrow.RecordBatch) (arrow.RecordBatch, error) {
	return vgi.MapColumn(params, batch, 0, array.NewStringBuilder,
		func(col arrow.Array, i int) string {
			return fmt.Sprintf("hello, %s!", vgi.GetStringValue(col, i))
		})
}

func main() {
	httpMode := flag.Bool("http", false, "Run as HTTP server instead of stdio")
	logFlags := vgi.RegisterLoggingFlags(flag.CommandLine)
	flag.Parse()
	if err := logFlags.Apply(); err != nil {
		log.Fatalf("logging flags: %v", err)
	}

	w := vgi.NewWorker(
		vgi.WithCatalogName("__NAME__"),
		vgi.WithCatalogComment("Worker generated by vgi-go new-worker"),
	)
	w.RegisterScalar(vgi.AsScalarFunction[greetArgs](&GreetFn{}))

	if *httpMode {
		if err := w.RunHttp("127.0.0.1:0"); err != nil {
			log.Fatal(err)
		}
		return
	}
	w.RunStdio()
}
